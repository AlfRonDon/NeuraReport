  "reshape_rules": [
    {
      "purpose": "Unpivot six FM reading and totalizer columns into per-meter rows",
      "strategy": "MELT",
      "columns": [
        {
          "as": "row_meter_id",
          "from": [
            "FM_101",
            "FM_102",
            "FM_103",
            "FM_104",
            "FM_105",
            "FM_106"
          ]
        },
