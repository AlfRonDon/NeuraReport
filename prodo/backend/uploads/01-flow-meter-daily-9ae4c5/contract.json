            "neuract__FM_TABLE.FM_103",
            "neuract__FM_TABLE.FM_104",
            "neuract__FM_TABLE.FM_105",
            "neuract__FM_TABLE.FM_106"
          ]
        },
        {
          "as": "row_totalizer",
          "from": [
            "neuract__FM_TABLE.FM_101_TOTALIZER",
            "neuract__FM_TABLE.FM_102_TOTALIZER",
            "neuract__FM_TABLE.FM_103_TOTALIZER",
            "neuract__FM_TABLE.FM_104_TOTALIZER",
            "neuract__FM_TABLE.FM_105_TOTALIZER",
            "neuract__FM_TABLE.FM_106_TOTALIZER"
          ]
        }
      ],
