{
  "tokens": {
    "scalars": [
      "plant_name",
      "location",
      "print_date",
      "date_from",
      "date_to",
      "recipe_code"
    ],
    "row_tokens": [
      "row_sl_no",
      "row_material_name",
      "row_set_wt",
      "row_ach_wt",
      "row_error_kg",
      "row_error_pct"
    ],
    "totals": [
      "total_set_wt",
      "total_ach_wt",
      "total_error_kg",
      "total_error_pct"
    ]
  },
  "mapping": {
    "plant_name": "PARAM:plant_name",
    "location": "PARAM:location",
    "print_date": "PARAM:print_date",
    "date_from": "PARAM:date_from",
    "date_to": "PARAM:date_to",
    "recipe_code": "PARAM:recipe_code",
    "row_sl_no": "INDEX",
    "row_material_name": "recipes.bin1_content",
    "row_set_wt": "recipes.bin1_sp",
    "row_ach_wt": "recipes.bin1_act",
    "row_error_kg": "COMPUTED",
    "row_error_pct": "COMPUTED"
  },
  "unresolved": [],
  "join": {
    "parent_table": "recipes",
    "parent_key": "id",
    "child_table": "recipes",
    "child_key": "id"
  },
  "date_columns": {
    "recipes": "start_time"
  },
  "filters": {
    "optional": {
      "date_from": "recipes.start_time",
      "date_to": "recipes.end_time",
      "recipe_code": "recipes.recipe_name"
    }
  },
  "group_aggregate": {
    "strategy": "sum",
    "columns": [
      "bin1_sp", "bin1_act",
      "bin2_sp", "bin2_act",
      "bin3_sp", "bin3_act",
      "bin4_sp", "bin4_act",
      "bin5_sp", "bin5_act",
      "bin6_sp", "bin6_act",
      "bin7_sp", "bin7_act",
      "bin8_sp", "bin8_act",
      "bin9_sp", "bin9_act",
      "bin10_sp", "bin10_act",
      "bin11_sp", "bin11_act",
      "bin12_sp", "bin12_act"
    ]
  },
  "reshape_rules": [
    {
      "purpose": "Unpivot 12 bin columns (wide) into long rows. After group_aggregate, bins are summed across all batches for the filtered recipe. MELT produces one row per material.",
      "strategy": "MELT",
      "columns": [
        {
          "as": "row_sl_no",
          "from": ["INDEX"]
        },
        {
          "as": "row_material_name",
          "from": [
            "recipes.bin1_content", "recipes.bin2_content", "recipes.bin3_content",
            "recipes.bin4_content", "recipes.bin5_content", "recipes.bin6_content",
            "recipes.bin7_content", "recipes.bin8_content", "recipes.bin9_content",
            "recipes.bin10_content", "recipes.bin11_content", "recipes.bin12_content"
          ]
        },
        {
          "as": "row_set_wt",
          "from": [
            "recipes.bin1_sp", "recipes.bin2_sp", "recipes.bin3_sp",
            "recipes.bin4_sp", "recipes.bin5_sp", "recipes.bin6_sp",
            "recipes.bin7_sp", "recipes.bin8_sp", "recipes.bin9_sp",
            "recipes.bin10_sp", "recipes.bin11_sp", "recipes.bin12_sp"
          ]
        },
        {
          "as": "row_ach_wt",
          "from": [
            "recipes.bin1_act", "recipes.bin2_act", "recipes.bin3_act",
            "recipes.bin4_act", "recipes.bin5_act", "recipes.bin6_act",
            "recipes.bin7_act", "recipes.bin8_act", "recipes.bin9_act",
            "recipes.bin10_act", "recipes.bin11_act", "recipes.bin12_act"
          ]
        }
      ]
    }
  ],
  "row_computed": {
    "row_error_kg": {
      "op": "subtract",
      "left": "row_ach_wt",
      "right": "row_set_wt"
    },
    "row_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": {
          "op": "subtract",
          "left": "row_ach_wt",
          "right": "row_set_wt"
        },
        "denominator": "row_set_wt"
      },
      "right": 100
    }
  },
  "totals_math": {
    "total_set_wt": {
      "op": "sum",
      "column": "row_set_wt"
    },
    "total_ach_wt": {
      "op": "sum",
      "column": "row_ach_wt"
    },
    "total_error_kg": {
      "op": "subtract",
      "left": {"op": "sum", "column": "row_ach_wt"},
      "right": {"op": "sum", "column": "row_set_wt"}
    },
    "total_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": {
          "op": "subtract",
          "left": {"op": "sum", "column": "row_ach_wt"},
          "right": {"op": "sum", "column": "row_set_wt"}
        },
        "denominator": {"op": "sum", "column": "row_set_wt"}
      },
      "right": 100
    }
  },
  "totals": {
    "total_set_wt": "COMPUTED",
    "total_ach_wt": "COMPUTED",
    "total_error_kg": "COMPUTED",
    "total_error_pct": "COMPUTED"
  },
  "formatters": {
    "row_set_wt": "number(0)",
    "row_ach_wt": "number(0)",
    "row_error_kg": "number(0)",
    "row_error_pct": "number(3)"
  },
  "order_by": {
    "rows": []
  },
  "header_tokens": [
    "plant_name",
    "location",
    "print_date",
    "date_from",
    "date_to",
    "recipe_code"
  ],
  "row_tokens": [
    "row_sl_no",
    "row_material_name",
    "row_set_wt",
    "row_ach_wt",
    "row_error_kg",
    "row_error_pct"
  ],
  "row_order": [],
  "literals": {},
  "notes": "Recipe Consumption Report (Aggregated). Uses group_aggregate to sum all bin_sp/bin_act columns across batches for the filtered recipe_code, then MELT unpivots 12 bins into material rows. Single flat table, no BLOCK_REPEAT. Recipe code passed as key_value filter."
}
