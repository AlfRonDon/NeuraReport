{
  "tokens": {
    "scalars": [
      "plant_name",
      "location",
      "print_date",
      "report_date",
      "recipe_name_header",
      "shift_no",
      "page_number",
      "total_pages"
    ],
    "row_tokens": [
      "row_bth_no",
      "row_material_name",
      "row_set_wt_kg",
      "row_act_wt_kg",
      "row_error_kg",
      "row_error_pct",
      "row_deviate_dur_sec"
    ],
    "totals": [
      "total_set_wt_kg",
      "total_act_wt_kg",
      "total_error_kg",
      "total_error_pct",
      "total_deviate_dur_sec"
    ]
  },
  "mapping": {
    "plant_name": "PARAM:plant_name",
    "location": "PARAM:location",
    "print_date": "PARAM:print_date",
    "report_date": "PARAM:report_date",
    "recipe_name_header": "recipes.recipe_name",
    "shift_no": "PARAM:shift_no",
    "page_number": "PARAM:page_number",
    "total_pages": "PARAM:total_pages",
    "row_bth_no": "recipes.bin_number",
    "row_material_name": "recipes.material_name",
    "row_set_wt_kg": "recipes.set_wt_kg",
    "row_act_wt_kg": "recipes.act_wt_kg",
    "row_error_kg": "recipes.error_kg",
    "row_error_pct": "recipes.error_pct",
    "row_deviate_dur_sec": "UNRESOLVED",
    "total_set_wt_kg": "recipes.total_set_wt_kg",
    "total_act_wt_kg": "recipes.total_act_wt_kg",
    "total_error_kg": "recipes.total_error_kg",
    "total_error_pct": "recipes.total_error_pct",
    "total_deviate_dur_sec": "UNRESOLVED"
  },
  "unresolved": [
    "row_deviate_dur_sec",
    "total_deviate_dur_sec"
  ],
  "join": {
    "parent_table": "",
    "parent_key": "",
    "child_table": "",
    "child_key": ""
  },
  "date_columns": {
    "recipes": "start_time"
  },
  "filters": {
    "optional": {
      "recipe_name_filter": "recipes.recipe_name"
    }
  },
  "reshape_rules": [
    {
      "purpose": "Unpivot 12 bin content columns into single material_name column with bin_number identifier",
      "strategy": "MELT",
      "columns": [
        {
          "as": "material_name",
          "from": [
            "recipes.bin1_content",
            "recipes.bin2_content",
            "recipes.bin3_content",
            "recipes.bin4_content",
            "recipes.bin5_content",
            "recipes.bin6_content",
            "recipes.bin7_content",
            "recipes.bin8_content",
            "recipes.bin9_content",
            "recipes.bin10_content",
            "recipes.bin11_content",
            "recipes.bin12_content"
          ]
        },
        {
          "as": "set_wt_kg",
          "from": [
            "recipes.bin1_sp",
            "recipes.bin2_sp",
            "recipes.bin3_sp",
            "recipes.bin4_sp",
            "recipes.bin5_sp",
            "recipes.bin6_sp",
            "recipes.bin7_sp",
            "recipes.bin8_sp",
            "recipes.bin9_sp",
            "recipes.bin10_sp",
            "recipes.bin11_sp",
            "recipes.bin12_sp"
          ]
        },
        {
          "as": "act_wt_kg",
          "from": [
            "recipes.bin1_act",
            "recipes.bin2_act",
            "recipes.bin3_act",
            "recipes.bin4_act",
            "recipes.bin5_act",
            "recipes.bin6_act",
            "recipes.bin7_act",
            "recipes.bin8_act",
            "recipes.bin9_act",
            "recipes.bin10_act",
            "recipes.bin11_act",
            "recipes.bin12_act"
          ]
        },
        {
          "as": "bin_number",
          "from": [
            "INDEX"
          ]
        }
      ],
      "order_by": []
    }
  ],
  "row_computed": {
    "row_error_kg": {
      "op": "subtract",
      "left": "act_wt_kg",
      "right": "set_wt_kg"
    },
    "row_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": "error_kg",
        "denominator": "set_wt_kg"
      },
      "right": 100
    }
  },
  "totals_math": {
    "total_set_wt_kg": {
      "op": "sum",
      "column": "set_wt_kg"
    },
    "total_act_wt_kg": {
      "op": "sum",
      "column": "act_wt_kg"
    },
    "total_error_kg": {
      "op": "sum",
      "column": "error_kg"
    },
    "total_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": {
          "op": "sum",
          "column": "error_kg"
        },
        "denominator": {
          "op": "sum",
          "column": "set_wt_kg"
        }
      },
      "right": 100
    }
  },
  "formatters": {
    "row_set_wt_kg": "number:2",
    "row_act_wt_kg": "number:2",
    "row_error_kg": "number:2",
    "row_error_pct": "number:2",
    "total_set_wt_kg": "number:2",
    "total_act_wt_kg": "number:2",
    "total_error_kg": "number:2",
    "total_error_pct": "number:2",
    "print_date": "date:%d/%m/%Y",
    "report_date": "date:%d/%m/%Y"
  },
  "order_by": {
    "rows": [
      "bin_number ASC"
    ]
  },
  "header_tokens": [
    "plant_name",
    "location",
    "print_date",
    "report_date",
    "recipe_name_header",
    "shift_no",
    "page_number",
    "total_pages"
  ],
  "row_tokens": [
    "row_bth_no",
    "row_material_name",
    "row_set_wt_kg",
    "row_act_wt_kg",
    "row_error_kg",
    "row_error_pct",
    "row_deviate_dur_sec"
  ],
  "totals": {
    "total_set_wt_kg": {
      "op": "sum",
      "column": "set_wt_kg"
    },
    "total_act_wt_kg": {
      "op": "sum",
      "column": "act_wt_kg"
    },
    "total_error_kg": {
      "op": "sum",
      "column": "error_kg"
    },
    "total_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": {
          "op": "sum",
          "column": "error_kg"
        },
        "denominator": {
          "op": "sum",
          "column": "set_wt_kg"
        }
      },
      "right": 100
    }
  },
  "row_order": [
    "bin_number",
    "ASC"
  ],
  "notes": "Batch dispensing report. Single recipes table with 12 wide bin columns melted into rows. Computed error metrics at row and totals level. Unresolved: deviation duration (row_deviate_dur_sec, total_deviate_dur_sec) and batch metadata tokens (batch_no, scale names, batch_date, start_times, recipe_code, recipe_no) not in catalog. Filter reshaped rows to exclude empty bins (material_name null/empty).",
  "literals": {}
}