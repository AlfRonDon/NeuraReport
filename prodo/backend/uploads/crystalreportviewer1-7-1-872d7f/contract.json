{
  "tokens": {
    "scalars": [
      "plant_name",
      "location",
      "from_date",
      "to_date",
      "print_date",
      "recipe_code",
      "company_name",
      "page_info"
    ],
    "row_tokens": [
      "row_sl_no",
      "row_material_name",
      "row_set_wt",
      "row_ach_wt",
      "row_error",
      "row_error_pct"
    ],
    "totals": [
      "total_set_wt",
      "total_ach_wt",
      "total_error",
      "total_error_pct"
    ]
  },
  "mapping": {
    "plant_name": "PARAM:plant_name",
    "location": "PARAM:location",
    "from_date": "PARAM:from_date",
    "to_date": "PARAM:to_date",
    "print_date": "PARAM:print_date",
    "recipe_code": "PARAM:recipe_code",
    "company_name": "PARAM:company_name",
    "page_info": "PARAM:page_info",
    "row_sl_no": "recipes.rowid",
    "row_material_name": "recipes.bin1_content",
    "row_set_wt": "recipes.bin1_sp",
    "row_ach_wt": "recipes.bin1_act",
    "row_error": "recipes.bin1_act",
    "row_error_pct": "recipes.bin1_act",
    "total_set_wt": "UNRESOLVED",
    "total_ach_wt": "UNRESOLVED",
    "total_error": "UNRESOLVED",
    "total_error_pct": "UNRESOLVED"
  },
  "unresolved": [],
  "join": {
    "parent_table": "",
    "parent_key": "",
    "child_table": "",
    "child_key": ""
  },
  "date_columns": {
    "recipes": "start_time"
  },
  "filters": {
    "optional": {}
  },
  "reshape_rules": [
    {
      "purpose": "Unpivot 12 bin material names into normalized material_name column",
      "strategy": "MELT",
      "columns": [
        {
          "as": "material_name",
          "from": [
            "recipes.bin1_content",
            "recipes.bin2_content",
            "recipes.bin3_content",
            "recipes.bin4_content",
            "recipes.bin5_content",
            "recipes.bin6_content",
            "recipes.bin7_content",
            "recipes.bin8_content",
            "recipes.bin9_content",
            "recipes.bin10_content",
            "recipes.bin11_content",
            "recipes.bin12_content"
          ]
        },
        {
          "as": "set_wt",
          "from": [
            "recipes.bin1_sp",
            "recipes.bin2_sp",
            "recipes.bin3_sp",
            "recipes.bin4_sp",
            "recipes.bin5_sp",
            "recipes.bin6_sp",
            "recipes.bin7_sp",
            "recipes.bin8_sp",
            "recipes.bin9_sp",
            "recipes.bin10_sp",
            "recipes.bin11_sp",
            "recipes.bin12_sp"
          ]
        },
        {
          "as": "ach_wt",
          "from": [
            "recipes.bin1_act",
            "recipes.bin2_act",
            "recipes.bin3_act",
            "recipes.bin4_act",
            "recipes.bin5_act",
            "recipes.bin6_act",
            "recipes.bin7_act",
            "recipes.bin8_act",
            "recipes.bin9_act",
            "recipes.bin10_act",
            "recipes.bin11_act",
            "recipes.bin12_act"
          ]
        }
      ],
      "order_by": []
    }
  ],
  "row_computed": {
    "row_sl_no": {
      "op": "row_number"
    },
    "row_error": {
      "op": "subtract",
      "left": "ach_wt",
      "right": "set_wt"
    },
    "row_error_pct": {
      "op": "divide",
      "numerator": "row_error",
      "denominator": "set_wt"
    }
  },
  "totals_math": {
    "total_set_wt": {
      "op": "sum",
      "column": "set_wt"
    },
    "total_ach_wt": {
      "op": "sum",
      "column": "ach_wt"
    },
    "total_error": {
      "op": "sum",
      "column": "row_error"
    },
    "total_error_pct": {
      "op": "divide",
      "numerator": {
        "op": "sum",
        "column": "row_error"
      },
      "denominator": {
        "op": "sum",
        "column": "set_wt"
      }
    }
  },
  "formatters": {
    "row_set_wt": "number:2",
    "row_ach_wt": "number:2",
    "row_error": "number:2",
    "row_error_pct": "number:4",
    "total_set_wt": "number:2",
    "total_ach_wt": "number:2",
    "total_error": "number:2",
    "total_error_pct": "number:4",
    "from_date": "date:%d/%m/%Y",
    "to_date": "date:%d/%m/%Y",
    "print_date": "date:%d/%m/%Y"
  },
  "order_by": {
    "rows": [
      "material_name",
      "ASC"
    ]
  },
  "header_tokens": [
    "plant_name",
    "location",
    "from_date",
    "to_date",
    "print_date",
    "recipe_code",
    "company_name",
    "page_info"
  ],
  "row_tokens": [
    "row_sl_no",
    "row_material_name",
    "row_set_wt",
    "row_ach_wt",
    "row_error",
    "row_error_pct"
  ],
  "totals": {
    "total_set_wt": {
      "op": "sum",
      "column": "set_wt"
    },
    "total_ach_wt": {
      "op": "sum",
      "column": "ach_wt"
    },
    "total_error": {
      "op": "sum",
      "column": "row_error"
    },
    "total_error_pct": {
      "op": "divide",
      "numerator": {
        "op": "sum",
        "column": "row_error"
      },
      "denominator": {
        "op": "sum",
        "column": "set_wt"
      }
    }
  },
  "row_order": [
    "material_name",
    "ASC"
  ],
  "notes": "Manufacturing consumption report comparing set vs achieved weights across 12 bins. MELT transformation creates one row per non-empty bin. Error metrics calculate deviation from target weights. Recipe filtered by name and date range.",
  "literals": {}
}